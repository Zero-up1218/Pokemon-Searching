<view wx:if="{{loading}}" class="loading-view">
  <view class="pokeball">
    <view class="pokeball-top"></view>
    <view class="pokeball-line"></view>
    <view class="pokeball-center"></view>
    <view class="pokeball-bottom"></view>
  </view>
  <text class="loading-text">加载中...</text>
</view>

<view wx:elif="{{error}}" class="loading-view">
  <text class="error-icon">😢</text>
  <text class="loading-text">加载失败</text>
  <view class="back-btn" bindtap="goBack">返回</view>
</view>

<scroll-view wx:elif="{{pokemon}}" scroll-y class="page">

  <!-- ── Header ─────────────────────────────────────────── -->
  <view
    class="header"
    style="background: linear-gradient(160deg, {{pokemon.typeColor}}ee 0%, {{pokemon.typeColor}}99 100%)"
  >
    <!-- Decorative Pokéball -->
    <view class="header-pokeball"></view>

    <view class="header-content">
      <view class="header-left">
        <view class="pokemon-id">{{pokemon.formattedId}}</view>
        <view class="pokemon-name">
          {{pokemon.chineseName ? pokemon.chineseName : pokemon.name}}
        </view>
        <view wx:if="{{pokemon.chineseName}}" class="pokemon-name-en">{{pokemon.name}}</view>
        <view class="type-row">
          <view
            wx:for="{{pokemon.types}}"
            wx:key="name"
            wx:for-item="type"
            class="type-badge"
            style="background-color: {{type.color}}"
          >{{type.nameCN}}</view>
        </view>
      </view>
      <image class="pokemon-image" src="{{pokemon.image}}" mode="aspectFit" />
    </view>
  </view>

  <!-- ── Body ───────────────────────────────────────────── -->
  <view class="body">

    <!-- Basic Info -->
    <view class="card">
      <view class="card-title">基本信息</view>
      <view class="info-grid">
        <view class="info-item">
          <text class="info-label">身高</text>
          <text class="info-value">{{pokemon.height}} m</text>
        </view>
        <view class="info-divider"></view>
        <view class="info-item">
          <text class="info-label">体重</text>
          <text class="info-value">{{pokemon.weight}} kg</text>
        </view>
      </view>
    </view>

    <!-- Abilities -->
    <view class="card" wx:if="{{pokemon.abilities.length > 0}}">
      <view class="card-title">特性</view>
      <view class="abilities">
        <view
          wx:for="{{pokemon.abilities}}"
          wx:key="name"
          class="ability-badge {{item.isHidden ? 'ability-hidden' : ''}}"
        >
          <text>{{item.name}}</text>
          <text wx:if="{{item.isHidden}}" class="hidden-label"> (隐藏)</text>
        </view>
      </view>
    </view>

    <!-- Description -->
    <view class="card" wx:if="{{pokemon.description}}">
      <view class="card-title">图鉴描述</view>
      <text class="description">{{pokemon.description}}</text>
    </view>

    <!-- Base Stats -->
    <view class="card">
      <view class="card-title">基础属性</view>
      <view wx:for="{{pokemon.stats}}" wx:key="name" class="stat-row">
        <text class="stat-name">{{item.name}}</text>
        <text class="stat-value">{{item.value}}</text>
        <view class="stat-bar-bg">
          <view
            class="stat-bar"
            style="width: {{item.percentage}}%; background-color: {{item.color}}"
          ></view>
        </view>
      </view>
      <view class="stat-total">
        <text class="stat-total-label">总计</text>
        <text class="stat-total-value">{{pokemon.totalStats}}</text>
      </view>
    </view>

  </view>
</scroll-view>
