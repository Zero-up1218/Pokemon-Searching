.page {
  height: 100vh;
  background-color: #f5f5f5;
}

/* ─── Loading / Error ───────────────────────────────────── */

.loading-view {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  background: #f5f5f5;
}

.loading-text {
  font-size: 30rpx;
  color: #999;
  margin-top: 20rpx;
}

.error-icon {
  font-size: 80rpx;
}

.back-btn {
  margin-top: 30rpx;
  padding: 16rpx 48rpx;
  background: #E3350D;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
}

/* ─── Pokéball Loader ───────────────────────────────────── */

.pokeball {
  width: 80rpx;
  height: 80rpx;
  position: relative;
  border-radius: 50%;
  border: 4rpx solid #333;
  overflow: hidden;
  animation: spin 1s linear infinite;
}

.pokeball-top {
  width: 100%;
  height: 50%;
  background: #E3350D;
}

.pokeball-bottom {
  width: 100%;
  height: 50%;
  background: #fff;
}

.pokeball-line {
  position: absolute;
  width: 100%;
  height: 6rpx;
  background: #333;
  top: 50%;
  transform: translateY(-50%);
  z-index: 2;
}

.pokeball-center {
  position: absolute;
  width: 24rpx;
  height: 24rpx;
  background: #fff;
  border-radius: 50%;
  border: 4rpx solid #333;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 3;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}

/* ─── Header ─────────────────────────────────────────────── */

.header {
  position: relative;
  padding: 48rpx 32rpx 100rpx;
  overflow: hidden;
}

/* large decorative pokeball ring behind the Pokémon */
.header-pokeball {
  position: absolute;
  right: -60rpx;
  top: -60rpx;
  width: 400rpx;
  height: 400rpx;
  border-radius: 50%;
  border: 48rpx solid rgba(255, 255, 255, 0.1);
}

.header-content {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  position: relative;
  z-index: 1;
}

.header-left {
  flex: 1;
}

.pokemon-id {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  font-weight: bold;
  margin-bottom: 8rpx;
}

.pokemon-name {
  font-size: 60rpx;
  font-weight: bold;
  color: #fff;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
  line-height: 1.1;
}

.pokemon-name-en {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  text-transform: capitalize;
  margin-top: 4rpx;
}

.type-row {
  display: flex;
  flex-wrap: wrap;
  margin-top: 16rpx;
}

.type-badge {
  padding: 6rpx 24rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #fff;
  font-weight: bold;
  margin-right: 10rpx;
  margin-bottom: 6rpx;
  opacity: 0.9;
}

.pokemon-image {
  width: 280rpx;
  height: 280rpx;
  flex-shrink: 0;
}

/* ─── Body ───────────────────────────────────────────────── */

.body {
  margin-top: -48rpx;
  border-radius: 40rpx 40rpx 0 0;
  background: #f5f5f5;
  padding: 32rpx 24rpx 48rpx;
  position: relative;
  z-index: 2;
}

/* ─── Card ───────────────────────────────────────────────── */

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 14rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

/* ─── Basic Info ─────────────────────────────────────────── */

.info-grid {
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.info-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.info-divider {
  width: 2rpx;
  height: 64rpx;
  background: #f0f0f0;
}

.info-label {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.info-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

/* ─── Abilities ──────────────────────────────────────────── */

.abilities {
  display: flex;
  flex-wrap: wrap;
}

.ability-badge {
  padding: 10rpx 28rpx;
  background: #f5f5f5;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #555;
  text-transform: capitalize;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}

.ability-hidden {
  background: #fff3e0;
  color: #e65100;
}

.hidden-label {
  font-size: 22rpx;
}

/* ─── Description ────────────────────────────────────────── */

.description {
  font-size: 28rpx;
  color: #666;
  line-height: 1.7;
}

/* ─── Stats ──────────────────────────────────────────────── */

.stat-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.stat-name {
  width: 96rpx;
  font-size: 24rpx;
  color: #999;
  flex-shrink: 0;
}

.stat-value {
  width: 64rpx;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  text-align: right;
  flex-shrink: 0;
}

.stat-bar-bg {
  flex: 1;
  height: 14rpx;
  background: #f0f0f0;
  border-radius: 7rpx;
  margin-left: 16rpx;
  overflow: hidden;
}

.stat-bar {
  height: 100%;
  border-radius: 7rpx;
}

.stat-total {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 8rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid #f0f0f0;
}

.stat-total-label {
  font-size: 28rpx;
  color: #666;
  font-weight: bold;
}

.stat-total-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}
